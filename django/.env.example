# Segredo próprio do Django (gere com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
DJANGO_SECRET_KEY=""
DJANGO_DEBUG="True"
DJANGO_ALLOWED_HOSTS="localhost,127.0.0.1"

# Banco próprio deste serviço, desacoplado do banco do gateway Next.js.
# Em dev, deixe em branco para usar SQLite local (django/db.sqlite3).
# Em produção, use uma URL do Postgres, ex.: postgres://user:senha@host:5432/nome
DATABASE_URL=""

# Chave pública RS256 usada para validar o access token do gateway Next.js.
# Copie o mesmo valor de JWT_ACCESS_PUBLIC_KEY_B64 do .env da raiz do projeto
# (gerado com: npm run gerar:chaves-rs256). Nunca copie a chave PRIVADA para cá.
JWT_ACCESS_PUBLIC_KEY_B64=""
