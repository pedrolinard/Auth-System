# Banco de dados
# Em desenvolvimento usamos SQLite local. Em produção, troque para uma URL do Postgres
# (ex.: Neon/Vercel Marketplace) sem precisar alterar o schema.
DATABASE_URL="file:./dev.db"

# Segredos usados para assinar os tokens JWT (gere valores fortes e únicos em produção)
# Gere cada um com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""
# Segredo do token de desafio de MFA (curta duração; use um valor diferente dos acima)
JWT_MFA_SECRET=""

# Segredo compartilhado para autorizar POST /api/cron/limpar-tokens (job de limpeza)
# Gere com: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
CRON_SECRET=""
