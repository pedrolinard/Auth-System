# Banco de dados — Postgres local, mesma instância compartilhada com o Django
# (django/), cada serviço com sua própria database (autenticacao / autenticacao_dominio).
# Em produção, troque por uma URL de um Postgres gerenciado (ex.: Neon/Vercel Marketplace).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/autenticacao"

# Par de chaves RS256 do token de acesso (assinado com a privada aqui; a pública
# é compartilhada com outros serviços, como o Django em django/, para eles
# verificarem o token sem precisar confiar num segredo simétrico).
# Gere com: npm run gerar:chaves-rs256
JWT_ACCESS_PRIVATE_KEY_B64=""
JWT_ACCESS_PUBLIC_KEY_B64=""

# Segredos usados para assinar os demais tokens JWT (gere valores fortes e únicos em produção)
# Gere cada um com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_REFRESH_SECRET=""
# Segredo do token de desafio de MFA (curta duração; use um valor diferente dos acima)
JWT_MFA_SECRET=""
# Segredo do token de verificação de e-mail (use um valor diferente dos acima)
JWT_VERIFICACAO_EMAIL_SECRET=""
# Segredo do token de redefinição de senha (use um valor diferente dos acima)
JWT_REDEFINICAO_SENHA_SECRET=""

# Chave AES-256 (32 bytes em base64) usada para cifrar dados sensíveis em
# repouso (ex.: segredo TOTP do MFA) — distinta dos segredos JWT acima, já
# que protege dados persistidos, não tokens efêmeros.
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MFA_ENCRYPTION_KEY=""

# Segredo compartilhado para autorizar POST /api/cron/limpar-tokens (job de limpeza)
# Gere com: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
CRON_SECRET=""

# URL do serviço Django (django/) usada pelo rewrite /api/dominio/* em next.config.ts
DJANGO_SERVICE_URL="http://localhost:8000"

# Envio de e-mail (verificação de conta) via Resend — https://resend.com/api-keys
# Sem essa chave, o link de verificação só é logado no console (comportamento de dev).
RESEND_API_KEY=""
# Remetente. onboarding@resend.dev funciona sem verificar domínio, mas só
# entrega pro e-mail cadastrado na conta Resend (modo sandbox) — pra enviar
# pra qualquer destinatário, verifique um domínio próprio no Resend e troque
# esse valor pra algo como "Auth Gateway <verificacao@seudominio.com>".
EMAIL_FROM="onboarding@resend.dev"
