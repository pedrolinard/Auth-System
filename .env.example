# Banco de dados
# Em desenvolvimento usamos SQLite local. Em produção, troque para uma URL do Postgres
# (ex.: Neon/Vercel Marketplace) sem precisar alterar o schema.
DATABASE_URL="file:./dev.db"

# Segredos usados para assinar os tokens JWT (gere valores fortes e únicos em produção)
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""
