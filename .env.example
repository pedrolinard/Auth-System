# Banco de dados
# Em desenvolvimento usamos SQLite local. Em produção, troque para uma URL do Postgres
# (ex.: Neon/Vercel Marketplace) sem precisar alterar o schema.
DATABASE_URL="file:./dev.db"

# Par de chaves RS256 do token de acesso (assinado com a privada aqui; a pública
# é compartilhada com outros serviços, como o Django em django/, para eles
# verificarem o token sem precisar confiar num segredo simétrico).
# Gere com: npm run gerar:chaves-rs256
JWT_ACCESS_PRIVATE_KEY_B64=""
JWT_ACCESS_PUBLIC_KEY_B64=""

# Segredos usados para assinar os demais tokens JWT (gere valores fortes e únicos em produção)
# Gere cada um com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_REFRESH_SECRET=""
# Segredo do token de desafio de MFA (curta duração; use um valor diferente dos acima)
JWT_MFA_SECRET=""

# Segredo compartilhado para autorizar POST /api/cron/limpar-tokens (job de limpeza)
# Gere com: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
CRON_SECRET=""

# URL do serviço Django (django/) usada pelo rewrite /api/dominio/* em next.config.ts
DJANGO_SERVICE_URL="http://localhost:8000"
