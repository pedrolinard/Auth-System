// Schema do Prisma - Sistema de Autenticação Intermediária
// Saiba mais em: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Papel {
  usuario
  admin
}

model Usuario {
  id             String              @id @default(cuid())
  nome           String
  email          String              @unique
  senhaHash      String
  mfaAtivado     Boolean             @default(false)
  mfaSecret      String?
  emailVerificado Boolean            @default(false)
  papel          Papel               @default(usuario)
  criadoEm       DateTime            @default(now())
  atualizadoEm   DateTime            @updatedAt
  tokens         TokenAtualizacao[]

  @@map("usuarios")
}

model TokenAtualizacao {
  id           String    @id @default(cuid())
  tokenHash    String    @unique
  usuarioId    String
  usuario      Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  criadoEm     DateTime  @default(now())
  expiraEm     DateTime
  revogadoEm   DateTime?

  @@index([usuarioId])
  @@map("tokens_atualizacao")
}

model LogAuditoria {
  id        String   @id @default(cuid())
  usuarioId String?
  email     String?
  evento    String
  ip        String?
  userAgent String?
  criadoEm  DateTime @default(now())

  @@index([usuarioId])
  @@map("logs_auditoria")
}
